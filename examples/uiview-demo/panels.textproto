# meridian.ui.v1.PanelBundle authored as textproto.
#
# Compiled to binpb by //examples/uiview-demo:panels (see BUILD.bazel)
# and loaded by demo.js at startup. Edit this file, save, and the
# runtime watch picks it up — no rebuild of the renderer needed for
# pure-descriptor changes (column re-order, label edit, format flip).

version: "demo-v1"

panels {
  panel_id: "claims"
  title: "Claims"
  table {
    populate {
      service: "pinax.claims.v1.ClaimsService"
      method: "ListClaims"
      bindings {
        request_field: "pdf_path"
        context: CURRENT_RESOURCE_PATH
      }
    }
    rows_field: "claims"
    item_noun: "claims"
    placeholder: "No claims."
    columns { header: "confidence" field_path: "confidence"   format: FLOAT_2DP    pref_width: 80 }
    columns { header: "category"   field_path: "category"     format: STRING       pref_width: 100 }
    columns { header: "claim"      field_path: "text"         format: STRING }
    columns { header: "entities"   field_path: "entity_names" format: STRING_LIST  pref_width: 180 }
  }
}

panels {
  panel_id: "review_tickets"
  title: "Review tickets"
  table {
    populate {
      service: "pinax.review.v1.ReviewService"
      method: "ListReviewTickets"
      bindings {
        request_field: "pdf_path"
        context: CURRENT_RESOURCE_PATH
      }
    }
    rows_field: "review_tickets"
    item_noun: "tickets"
    placeholder: "No tickets."
    columns { header: "state"     field_path: "state"                     format: STRING pref_width: 80 }
    columns { header: "ticket_id" field_path: "ticket_id"                 format: STRING pref_width: 180 }
    columns { header: "rationale" field_path: "rationale"                 format: STRING pref_width: 260 }
    columns { header: "subject"   field_path: "subject.claim.claim_text"  format: STRING }
  }
}

panels {
  panel_id: "sparql"
  title: "SPARQL"
  adhoc { handler_id: "sparql" }
}

# LlmPromptPanel example — author + fill a templated LLM prompt.
# Shows the slot/template separation: {{slot}} tokens in the system
# and user templates resolve from the `slots` block, where each
# slot reuses a FormField widget for its input collection.
#
# v0 is preview-only: the renderer substitutes the filled slots
# into the templates and shows the rendered prompt. To actually
# call the API, pair this panel with an LroPanel whose start RPC
# accepts the rendered prompt as input.
panels {
  panel_id: "summarize_source"
  title: "Summarize source file"
  llm_prompt {
    description: "Summarize a single source file for a curator who's never seen it."
    system_template:
      "You are a careful technical writer producing two-sentence "
      "code summaries. You output prose only — no markdown, no "
      "code fences, no lists."
    user_template:
      "Summarize the file `{{file_path}}` (language: {{language}}) "
      "in exactly two sentences. The file content follows:\n\n"
      "```\n{{file_content}}\n```\n\n"
      "Sentence 1: what the file's central type or function is. "
      "Sentence 2: how it fits into a larger system."
    slots {
      name: "file_path"
      field {
        field_id: "file_path"
        label: "File path"
        text { default_value: "src/lib.rs" }
      }
    }
    slots {
      name: "language"
      field {
        field_id: "language"
        label: "Language"
        enum_selection {
          allowed_values: "rust"
          allowed_values: "python"
          allowed_values: "go"
          allowed_values: "typescript"
          allowed_values: "java"
          allowed_values: "cpp"
          allowed_values: "c"
          default_value: "rust"
        }
      }
    }
    slots {
      name: "file_content"
      field {
        field_id: "file_content"
        label: "File content"
        description: "Paste the full file contents here."
        text {}
      }
      multi_line: true
      rows: 20
    }
    model_hint {
      provider: "anthropic"
      model: "claude-sonnet-4-5"
      max_tokens: 256
      temperature: 0.0
    }
  }
}
